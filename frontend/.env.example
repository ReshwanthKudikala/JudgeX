# =========================================================================
# JudgeX Frontend — Environment Template
# Copy to `.env`. Only VITE_-prefixed vars are exposed to the client.
# =========================================================================

# Base URL of the JudgeX backend REST API (see docs/API_SPECIFICATION.md).
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Public-facing app name (optional).
VITE_APP_NAME=JudgeX

# Release metadata (set by CI / Docker build args).
VITE_APP_VERSION=0.1.0
VITE_GIT_SHA=dev
VITE_BUILD_TIME=
