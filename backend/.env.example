# =========================================================================
# JudgeX Backend — Environment Template
# Copy to `.env` and fill values. NEVER commit the real `.env`.
# =========================================================================

# --- Server ---
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS (frontend dev URL).
CORS_ORIGIN=http://localhost:5173
# Max JSON / urlencoded body size (express syntax).
JSON_BODY_LIMIT=1mb

# --- PostgreSQL ---
DATABASE_URL=postgres://judgex:judgex@localhost:5432/judgex
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
# If true, startup aborts when PostgreSQL cannot be reached (set false for
# offline/degraded local dev without the docker services running).
DB_REQUIRED=true

# --- Redis (cache + BullMQ + rate limiting) ---
REDIS_URL=redis://localhost:6379
# If true, startup aborts when Redis cannot be reached.
REDIS_REQUIRED=true

# --- Infrastructure startup retry policy ---
INFRA_STARTUP_RETRIES=5
INFRA_STARTUP_RETRY_DELAY_MS=1000

# --- JWT (auth) ---
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m

# --- Password Hashing (bcrypt) ---
BCRYPT_SALT_ROUNDS=12

# --- Email (console logs by default; set EMAIL_PROVIDER=smtp for real delivery) ---
EMAIL_PROVIDER=console
EMAIL_FROM=JudgeX <noreply@judgex.local>
APP_PUBLIC_URL=http://localhost:5173
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- Rate Limiting (Redis fixed-window; see docs/SECURITY.md) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FORGOT_PASSWORD_MAX=5
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=900000
RATE_LIMIT_RESEND_VERIFICATION_MAX=5
RATE_LIMIT_RESEND_VERIFICATION_WINDOW_MS=900000
RATE_LIMIT_FORCE_IN_TEST=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_SUBMISSION_MAX=60
RATE_LIMIT_SUBMISSION_WINDOW_MS=60000
RATE_LIMIT_AI_MAX=20
RATE_LIMIT_AI_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=120
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_CONTEST_JOIN_MAX=15
RATE_LIMIT_CONTEST_JOIN_WINDOW_MS=60000
RATE_LIMIT_PROBLEMS_MAX=240
RATE_LIMIT_PROBLEMS_WINDOW_MS=60000

# --- AI Provider (default is FREE local Ollama; OpenAI optional) ---
# AI_PROVIDER: ollama | openai   (default: ollama)
AI_PROVIDER=ollama
# Ollama (default, no key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# OpenAI (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Docker Sandbox (judge execution limits) ---
JUDGE_TIME_LIMIT_MS=2000
JUDGE_MEMORY_LIMIT_MB=256
JUDGE_PID_LIMIT=64
JUDGE_WORKER_CONCURRENCY=2
JUDGE_FAIL_FAST=true

# --- Object Storage (large test-case payloads; optional in dev) ---
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# --- Logging ---
LOG_LEVEL=info
# auto | json | pretty  (auto = pretty in development, json otherwise)
LOG_FORMAT=auto

# --- Stuck-submission reaper (cleanup worker) ---
# Scans for queued rows that missed enqueue (persist-before-enqueue safety net).
REAPER_INTERVAL_MS=60000
REAPER_STUCK_THRESHOLD_MS=60000
REAPER_BATCH_SIZE=100

# --- Feature flags ---
FEATURE_AI_COMPILE_EXPLANATION=true
FEATURE_AI_ADVANCED=true
