# =========================================================================
# JudgeX Backend — Production Environment Template
# Copy to `.env` on the server. NEVER commit real secrets.
# See docs/SECURITY.md for hardening notes.
# =========================================================================

NODE_ENV=production
PORT=4000

# Comma-separated HTTPS frontend origins (no localhost in real deploys).
CORS_ORIGIN=https://judgex.app,https://www.judgex.app
# Origin used in email verification / password-reset links.
FRONTEND_URL=https://judgex.app
# Local prod Docker / Vite hybrid ONLY — never enable on public hosts.
ALLOW_LOCALHOST_CORS_IN_PRODUCTION=false
JSON_BODY_LIMIT=1mb

# --- Email (console by default; Gmail SMTP optional) ---
EMAIL_PROVIDER=console
EMAIL_FROM=JudgeX <noreply@judgex.local>
# Gmail requires 2-Step Verification + an App Password (never your normal password).
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=JudgeX <your.address@gmail.com>
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.address@gmail.com
# SMTP_PASS=your-16-char-app-password

# --- PostgreSQL (required) ---
DATABASE_URL=postgres://judgex_user:CHANGE_ME@db.internal:5432/judgex
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_REQUIRED=true

# --- Redis (required — BullMQ + rate limiting) ---
REDIS_URL=redis://redis.internal:6379
REDIS_REQUIRED=true

INFRA_STARTUP_RETRIES=10
INFRA_STARTUP_RETRY_DELAY_MS=2000

# --- JWT (>=32 chars, unique per environment) ---
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=15m

BCRYPT_SALT_ROUNDS=12

# --- Rate limiting (must stay enabled in production) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FORCE_IN_TEST=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_SUBMISSION_MAX=60
RATE_LIMIT_SUBMISSION_WINDOW_MS=60000
RATE_LIMIT_AI_MAX=20
RATE_LIMIT_AI_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=120
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_CONTEST_JOIN_MAX=15
RATE_LIMIT_CONTEST_JOIN_WINDOW_MS=60000
RATE_LIMIT_PROBLEMS_MAX=240
RATE_LIMIT_PROBLEMS_WINDOW_MS=60000

# --- AI ---
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama.internal:11434
OLLAMA_MODEL=llama3
# OPENAI_API_KEY= only when AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# --- Judge sandbox ---
JUDGE_TIME_LIMIT_MS=2000
JUDGE_MEMORY_LIMIT_MB=256
JUDGE_PID_LIMIT=64
JUDGE_WORKER_CONCURRENCY=4
JUDGE_FAIL_FAST=true
# JUDGE_WORKSPACE_DIR=/var/judgex/workspace
# JUDGE_WORKSPACE_HOST_DIR=/absolute/host/path/to/.judge-workspaces

# --- Object storage (optional) ---
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

LOG_LEVEL=info

REAPER_INTERVAL_MS=60000
REAPER_STUCK_THRESHOLD_MS=60000
REAPER_BATCH_SIZE=100

FEATURE_AI_COMPILE_EXPLANATION=true
FEATURE_AI_ADVANCED=true
