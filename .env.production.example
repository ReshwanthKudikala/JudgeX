# JudgeX production environment (docker compose)
# Copy to `.env.production` at the repo root and fill secrets.
# NEVER commit the real file.

# --- Build / release metadata ---
APP_VERSION=0.1.0
GIT_SHA=unknown
BUILD_TIME=

# --- Public HTTP ---
HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443
# Optional host path with fullchain.pem + privkey.pem for TLS
NGINX_CERTS_DIR=./docker/nginx/certs

# Must match the public site origin browsers use (no localhost in production).
CORS_ORIGIN=https://judgex.example

# --- Postgres ---
POSTGRES_USER=judgex
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=judgex

# --- API ---
PORT=4000
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=15m
BCRYPT_SALT_ROUNDS=12
JSON_BODY_LIMIT=1mb
LOG_LEVEL=info
LOG_FORMAT=json

RATE_LIMIT_ENABLED=true
DB_REQUIRED=true
REDIS_REQUIRED=true

# --- AI ---
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# --- Judge ---
JUDGE_TIME_LIMIT_MS=2000
JUDGE_MEMORY_LIMIT_MB=256
JUDGE_PID_LIMIT=64
JUDGE_WORKER_CONCURRENCY=2
JUDGE_FAIL_FAST=true

# --- Frontend build args ---
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=JudgeX
