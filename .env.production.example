# =========================================================================
# JudgeX — Production Environment Template
# Copy to `.env.production` at the repo root and fill secrets.
# NEVER commit the real `.env.production`.
#
# Usage with Compose:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Compose overrides DATABASE_URL and REDIS_URL to the internal service DNS
# names (`postgres`, `redis`). Values below for those two keys are documentation
# only when using docker-compose.prod.yml.
# =========================================================================

# --- Compose / Postgres bootstrap ---
POSTGRES_USER=judgex
POSTGRES_PASSWORD=replace-with-a-strong-url-safe-password
POSTGRES_DB=judgex

# Host port published for the API (container always listens on 4000)
API_HOST_PORT=4000

# --- Server ---
NODE_ENV=production
PORT=4000
# Comma-separated allowed origins (your deployed frontend).
CORS_ORIGIN=https://your-frontend.example.com

# --- PostgreSQL (overridden by compose to postgres:5432) ---
DATABASE_URL=postgres://judgex:replace-with-a-strong-url-safe-password@postgres:5432/judgex
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_REQUIRED=true

# --- Redis (overridden by compose to redis:6379) ---
REDIS_URL=redis://redis:6379
REDIS_REQUIRED=true

# --- Infrastructure startup retry policy ---
INFRA_STARTUP_RETRIES=10
INFRA_STARTUP_RETRY_DELAY_MS=2000

# --- JWT (REQUIRED in production: ≥ 32 characters) ---
JWT_SECRET=replace-with-at-least-32-random-characters!!
JWT_EXPIRES_IN=15m

# --- Password Hashing ---
BCRYPT_SALT_ROUNDS=12

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- AI Provider ---
# Default remains local Ollama. Production compose does NOT start Ollama.
# Options:
#   1) Point OLLAMA_BASE_URL at a reachable Ollama (e.g. host.docker.internal)
#   2) Set AI_PROVIDER=openai + OPENAI_API_KEY
#   3) Disable FEATURE_AI_COMPILE_EXPLANATION
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Docker Sandbox (judge worker) ---
JUDGE_TIME_LIMIT_MS=2000
JUDGE_MEMORY_LIMIT_MB=256
JUDGE_PID_LIMIT=64
JUDGE_WORKER_CONCURRENCY=2

# --- Object Storage (optional) ---
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# --- Logging ---
LOG_LEVEL=info

# --- Stuck-submission reaper (cleanup worker) ---
REAPER_INTERVAL_MS=60000
REAPER_STUCK_THRESHOLD_MS=60000
REAPER_BATCH_SIZE=100

# --- Feature flags ---
FEATURE_AI_COMPILE_EXPLANATION=true
